{
  "manifest_version": 3,
  "name": "AI Career Scout Agent",
  "version": "1.0",
  "description": "Tracks professional reading behavior to generate custom AI learning blueprints.",
  "permissions": [
    "history",
    "tabs",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' http://127.0.0.1:8000 http://localhost:8000"
  }
}